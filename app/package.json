{
    "name": "voixify",
    "version": "2.0.0",
    "description": "Premium AI dictation app — Voice to text with LLM correction",
    "author": "Brainditech",
    "main": "electron.cjs",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "node --no-deprecation node_modules/concurrently/dist/bin/concurrently.js -k \"node --no-deprecation ../backend/src/index.js\" \"vite\" \"wait-on http://localhost:5173 && electron --no-deprecation .\"",
        "build": "vite build",
        "preview": "vite preview",
        "electron": "electron --no-deprecation .",
        "dist": "npm run build && electron-builder"
    },
    "dependencies": {
        "cors": "^2.8.6",
        "dotenv": "^17.3.1",
        "express": "^5.2.1",
        "express-rate-limit": "^8.2.1",
        "form-data": "^4.0.5",
        "multer": "^2.1.0",
        "node-fetch": "^3.3.2",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "zustand": "^4.4.7"
    },
    "devDependencies": {
        "@types/react": "^18.2.0",
        "@types/react-dom": "^18.2.0",
        "@vitejs/plugin-react": "^4.2.1",
        "concurrently": "^8.2.2",
        "electron": "^28.1.0",
        "electron-builder": "^24.9.1",
        "typescript": "^5.3.3",
        "vite": "^5.0.10",
        "vite-plugin-electron": "^0.28.4",
        "wait-on": "^7.2.0"
    },
    "build": {
        "appId": "com.brainditech.voixify",
        "productName": "Voixify",
        "win": {
            "target": "nsis",
            "icon": "public/icon.ico"
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true,
            "createDesktopShortcut": true,
            "createStartMenuShortcut": true,
            "shortcutName": "Voixify"
        },
        "files": [
            "**/*",
            "../backend/src/**/*"
        ],
        "directories": {
            "output": "dist-electron"
        }
    }
}