# ============================================================
# Voixify — Environment Configuration
# Copy this file to .env and adjust values for your setup
# ============================================================

# Backend port (accessible from Electron app)
BACKEND_PORT=3001

# Your Whisper Docker API URL
# If Whisper runs on your host machine (docker container):
WHISPER_URL=http://host.docker.internal:8000

# Ollama URL (installed on your machine)
# From within Docker, we reach the host via host.docker.internal
OLLAMA_URL=http://host.docker.internal:11434

# Default Ollama model to use for text correction
OLLAMA_MODEL=kimi-k2.5:cloud

# Deepgram API key (required for speech-to-text)
DEEPGRAM_KEY=your_deepgram_api_key_here
